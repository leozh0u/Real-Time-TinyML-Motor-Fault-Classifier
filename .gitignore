# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# STM32CubeIDE / STM32CubeMX
firmware/Debug/
firmware/Release/
firmware/**/Debug/
firmware/**/Release/
