# Data (raw/processed can be large; sample/ is committed)
data/raw/*
data/processed/*
!data/raw/README.md
!data/processed/README.md

# Benchmark artifacts that are regenerated
benchmarks/results/*.csv
benchmarks/plots/*.png
!benchmarks/results/README.md
!benchmarks/plots/README.md

# OS
.DS_Store
